# Public site
NEXT_PUBLIC_SITE_URL=https://copperai.app

# Supabase (https://supabase.com/dashboard/project/_/settings/api)
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# OpenAI (single shared key — owner pays)
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini

# ElevenLabs — voiceovers + instant voice clone (https://elevenlabs.io/app)
ELEVENLABS_API_KEY=

# Replicate — image generation (Flux) + image-to-video (Kling)
# https://replicate.com/account/api-tokens
REPLICATE_API_TOKEN=
REPLICATE_IMAGE_MODEL=black-forest-labs/flux-1.1-pro
REPLICATE_VIDEO_MODEL=kwaivgi/kling-v2.1

# Stripe (https://dashboard.stripe.com/apikeys)
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=

# Stripe price IDs — create products in dashboard, paste price_xxx ids here
STRIPE_PRICE_CREATOR=
STRIPE_PRICE_PRO=
STRIPE_PRICE_AGENCY=

# Solo-owner escape hatch — set to "true" to unlock every tier limit without
# configuring Stripe. Intended for the app owner; leave OFF in any public
# deploy. When true, every signed-in user gets Agency-tier permissions.
BYPASS_PAYWALL=true

# ─── Multi-provider asset generation (Phase 1 — all optional) ──────────
# Each provider is auto-detected. If its key is missing, the picker shows
# "+ Add API key" instead of "Ready" — nothing crashes.

# ImagineArt (vyro.ai) — image + video (https://www.imagine.art/dashboard/api)
IMAGINEART_API_KEY=

# PicsArt — image + thumbnail (https://console.picsart.io/)
PICSART_API_KEY=

# HeyGen — AI avatar video (https://app.heygen.com/settings/api)
HEYGEN_API_KEY=

# fal.ai — proxy for Higgsfield video models (https://fal.ai/dashboard/keys)
FAL_KEY=

# Google Vertex AI — Imagen 3/4. Same model that powers ImageFX.
# Project: https://console.cloud.google.com/vertex-ai
GOOGLE_VERTEX_PROJECT_ID=
GOOGLE_VERTEX_LOCATION=us-central1
GOOGLE_VERTEX_ACCESS_TOKEN=

# PlayHT — 800+ voices (https://play.ht/studio/api-access)
PLAYHT_API_KEY=
PLAYHT_USER_ID=
