# Copy to .env and fill in values. .env is gitignored.

# ElevenLabs (voiceover)
ELEVENLABS_API_KEY=
# Default voice from elevenlabs.io/app/voice-library - override if you switch
ELEVENLABS_VOICE_ID=uf0ZrRtyyJlbbGIn43uD
ELEVENLABS_MODEL=eleven_multilingual_v2

# Google Gemini (image generation - "Nano Banana" = gemini-2.5-flash-image)
# Get key at https://aistudio.google.com/apikey
GEMINI_API_KEY=
GEMINI_IMAGE_MODEL=gemini-2.5-flash-image

# YouTube Data API (upload automation - optional, set up later)
YOUTUBE_API_KEY=
