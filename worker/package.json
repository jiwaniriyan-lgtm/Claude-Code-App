{
  "name": "copperai-worker",
  "version": "1.0.0",
  "private": true,
  "description": "Background worker that processes render_jobs (video assembly) using FFmpeg.",
  "main": "dist/index.js",
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "start": "node dist/index.js",
    "dev": "ts-node-dev --transpile-only --respawn src/index.ts",
    "once": "ts-node-dev --transpile-only --no-notify --no-deps src/index.ts --once"
  },
  "dependencies": {
    "@supabase/supabase-js": "^2.45.4",
    "@ffmpeg-installer/ffmpeg": "^1.1.0",
    "fluent-ffmpeg": "^2.1.3",
    "node-fetch": "^3.3.2"
  },
  "devDependencies": {
    "@types/fluent-ffmpeg": "^2.1.27",
    "@types/node": "^22.7.5",
    "ts-node-dev": "^2.0.0",
    "typescript": "^5.6.3"
  }
}
