# ─── Anthropic Claude ────────────────────────────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-...
# Default model — use the latest Claude Sonnet for best cost/quality balance
CLAUDE_MODEL=claude-sonnet-4-6

# ─── Google Sheets ───────────────────────────────────────────────────────────
# Path to your Google service-account JSON (download from Google Cloud Console)
GOOGLE_SERVICE_ACCOUNT_JSON=service_account.json
# The ID from your spreadsheet URL: docs.google.com/spreadsheets/d/<SPREADSHEET_ID>/edit
SPREADSHEET_ID=your_spreadsheet_id_here
TOPICS_SHEET=Topics
MUSIC_SHEET=Music
LOG_SHEET=ErrorLog

# ─── json2video ──────────────────────────────────────────────────────────────
JSON2VIDEO_API_KEY=your_json2video_key_here
JSON2VIDEO_BASE_URL=https://api.json2video.com/v2
# How often (seconds) to poll for render status
VIDEO_POLL_INTERVAL=15
# Give up after this many seconds
VIDEO_POLL_TIMEOUT=600

# ─── YouTube Data API v3 ─────────────────────────────────────────────────────
# OAuth 2.0 client-secrets JSON downloaded from Google Cloud Console
YOUTUBE_CLIENT_SECRETS_JSON=client_secrets.json
# Token is saved automatically after first OAuth login
YOUTUBE_TOKEN_JSON=youtube_token.json
# 22 = People & Blogs  (see YouTube category IDs for full list)
YOUTUBE_CATEGORY_ID=22
# public | unlisted | private
YOUTUBE_PRIVACY_STATUS=public

# ─── Scheduler ───────────────────────────────────────────────────────────────
# Standard 5-field cron: minute hour day month day-of-week
# Default: every day at 09:00 UTC
SCHEDULE_CRON=0 9 * * *

# ─── Retry / resilience ──────────────────────────────────────────────────────
MAX_RETRIES=3
RETRY_BACKOFF=2.0
